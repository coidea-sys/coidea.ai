{
  "name": "coidea.ai",
  "version": "0.1.0",
  "description": "AI与Human深度混合协作社区 | AI-Human Hybrid Collaboration Community",
  "main": "backend/index.js",
  "scripts": {
    "start": "node backend/index.js",
    "dev": "nodemon backend/index.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "contract:compile": "hardhat compile",
    "contract:test": "hardhat test",
    "node": "hardhat node",
    "deploy:local": "hardhat run scripts/deploy.js --network localhost",
    "deploy:amoy:full": "hardhat run scripts/deploy-amoy.js --network amoy",
    "deploy:amoy": "hardhat run scripts/deploy.js --network amoy",
    "deploy:polygon": "hardhat run scripts/deploy.js --network polygon",
    "env:local": "node scripts/env-manager.js localhost",
    "env:amoy": "node scripts/env-manager.js amoy",
    "env:polygon": "node scripts/env-manager.js polygon",
    "env:status": "node scripts/env-manager.js status",
    "verify:amoy": "hardhat verify --network amoy",
    "verify:polygon": "hardhat verify --network polygon",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "keywords": [
    "AI",
    "Web4",
    "DAO",
    "Agent",
    "Collaboration",
    "ERC8004"
  ],
  "author": "Danny & Kimi Claw",
  "license": "MIT",
  "dependencies": {
    "@openzeppelin/contracts": "^4.9.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "ethers": "^6.16.0",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "hardhat": "^2.19.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2"
  }
}
