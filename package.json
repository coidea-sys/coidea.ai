{
  "name": "coidea-contracts",
  "version": "2.0.0",
  "description": "coidea.ai smart contracts",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test --network hardhat",
    "test:human": "hardhat test test/human --network hardhat",
    "test:agent": "hardhat test test/agent --network hardhat",
    "test:task": "hardhat test test/task --network hardhat",
    "coverage": "hardhat coverage --network hardhat",
    "deploy:local": "hardhat run scripts/deploy-all.js --network localhost",
    "deploy:amoy": "hardhat run scripts/deploy-all.js --network polygonAmoy",
    "verify:amoy": "node scripts/verify-sourcify-all.js",
    "lint": "solhint 'contracts/**/*.sol'",
    "format": "prettier --write 'contracts/**/*.sol'"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "hardhat": "^2.19.0",
    "solhint": "^4.0.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0",
    "dotenv": "^16.3.0"
  }
}
