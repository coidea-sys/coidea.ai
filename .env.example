# ============================================
# coidea.ai 多环境配置
# 复制为 .env 后填入实际值
# ============================================

# 当前环境: localhost | polygonAmoy | polygon
NETWORK=localhost

# ============================================
# 本地开发环境 (Hardhat Network)
# ============================================
# 本地节点私钥（Hardhat 默认账户 #0，仅本地使用）
# Hardhat 默认账户列表：https://hardhat.org/hardhat-network/docs/reference#initial-state
LOCAL_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# ============================================
# 测试网环境 (Polygon Amoy)
# ============================================
# Amoy RPC Endpoint
# 可选：Alchemy, Infura, 或公共 RPC
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology

# 部署钱包私钥（必须有 Amoy POL 测试币）
# 获取测试币：https://faucet.polygon.technology/
PRIVATE_KEY=your_private_key_here

# PolygonScan API Key（用于合约验证）
# 获取：https://polygonscan.com/myapikey
# Amoy 和主网共用同一个 API Key
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here

# ============================================
# 主网环境 (Polygon Mainnet)
# ============================================
# 主网 RPC（推荐 Alchemy/Infura/QuickNode）
POLYGON_MAINNET_RPC=https://polygon-rpc.com

# 主网部署钱包（⚠️ 必须与测试网钱包分开！）
MAINNET_PRIVATE_KEY=your_mainnet_private_key_here

# ============================================
# 合约地址（部署后自动填充）
# ============================================
# 本地环境 (Hardhat/Localhost)
LOCALHOST_AI_AGENT_REGISTRY_ADDRESS=
LOCALHOST_HUMAN_LEVEL_NFT_ADDRESS=
LOCALHOST_TASK_REGISTRY_ADDRESS=
LOCALHOST_X402_PAYMENT_ADDRESS=
LOCALHOST_COMMUNITY_GOVERNANCE_ADDRESS=

# Amoy 测试网
AMOY_AI_AGENT_REGISTRY_ADDRESS=
AMOY_HUMAN_LEVEL_NFT_ADDRESS=
AMOY_TASK_REGISTRY_ADDRESS=
AMOY_X402_PAYMENT_ADDRESS=
AMOY_COMMUNITY_GOVERNANCE_ADDRESS=

# Polygon 主网
POLYGON_AI_AGENT_REGISTRY_ADDRESS=
POLYGON_HUMAN_LEVEL_NFT_ADDRESS=
POLYGON_TASK_REGISTRY_ADDRESS=
POLYGON_X402_PAYMENT_ADDRESS=
POLYGON_COMMUNITY_GOVERNANCE_ADDRESS=

# ============================================
# 后端配置
# ============================================
PORT=3000
NODE_ENV=development

